<% content_for :background_image do %>
  <div class="home-bg"></div>
<% end %>

<div class="container-fluid">
  <div class="row justify-content-center hero-section align-items-center">
    <div class="container col-12 col-md-9 col-xxl-7">
      <h1 class="display-1 rubik-dirt-regular text-shadow-gray">
        <span class="text-white">Talk is cheap. </span><span>Our work speaks for itself.</span>
      </h1>
      <p class="rubik-dirt-regular fs-3 text-shadow text-white">
      See what we've done for your neighbours below.
      </p>
      <div class="d-flex justify-content-center">
        <a href="#details" class="shadow px-4 btn btn-warning cta-btn-lg py-2 fs-5 mt-5 saira-stencil-one-regular">
          See Below
          <i class="bi bi-chevron-down"></i>
        </a>
      </div>
    </div>
  </div>
</div>

<section id="details" class="pb-4">
  <div class="container-fluid blur pt-5 pb-1">
    <h1 class="display-3 rubik-dirt-regular text-white mb-5 text-center">Recent Work</h1>
    <% @jobs.each do |job| %>
      <div class="row justify-content-center flex-wrap-reverse px-0 py-2 py-md-3">
        <div class="d-none d-md-block col-md-3 col-xxl-2">
          <% job.images.each do |image| %>
            <%= image_tag image.variant(:thumb), width: 300, height: 300, class: "img-fluid w-100 mb-3" %>
          <% end %>
        </div>

        <div class="col-12 col-sm-10 col-md-8 col-lg-7 col-xxl-6">
          <div class="card bg-transparent border-0 rounded-0">


                  <div id="carouselJob-<%= job.id %>" class= "carousel slide">
                    <div class="carousel-inner">

                      <div class="carousel-item active">
                            <%= image_tag job.main_image.variant(:large), width: 1000, height: 1000, class: "img-fluid w-100 carousel-image" %>
                      </div>

                      <% job.images.each do |image| %>
                        <div class="carousel-item">
                              <%= image_tag image.variant(:large), width: 1000, height: 1000, class: "img-fluid w-100 carousel-image" %>
                        </div>
                      <% end %>

                    </div>

                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselJob-<%= job.id %>" data-bs-slide="prev">
                      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                      <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carouselJob-<%= job.id %>" data-bs-slide="next">
                      <span class="carousel-control-next-icon" aria-hidden="true"></span>
                      <span class="visually-hidden">Next</span>
                    </button>

                  </div>

              <div class="card-body d-flex flex-column justify-content-between">

                <div class="card-text saira-stencil-one-regular text-white">
                  <p><em><%= job.location %></em></p>
                  <p class="opacity-75"><%= job.description %></p>
                </div>

              </div>
          </div>
        </div>

      </div>
        <div class="container px-5 mb-5 border-bottom">
        </div>
    <% end %>

    <div class="container d-flex flex-column align-items-center pb-5">
      <h3 class="rubik-dirt-regular text-center pt-3 mb-3 text-shadow-gray">
        Have Questions?<span class="text-white"> Just call.</span>
      </h3>
      <%= link_to "Call Today", "tel:+17344507995", class: "btn btn-warning shadow px-4 cta-btn-lg saira-stencil-one-regular fs-5" %>
    </div>

  </div>
</section>
