<% content_for :background_image do %>
  <div class="home-bg"></div>
<% end %>

<div class="container-fluid">
  <div class="row justify-content-center hero-section align-items-center">
    <div class="container col-12 col-md-8">
      <h1 class="display-1 rubik-dirt-regular text-shadow-light">
        <span class="text-white">Talk is cheap. </span><span>Our work speaks for itself.</span>
      </h1>
      <p class="rubik-dirt-regular fs-3 text-shadow text-white">
      See what we've done for your neighbours in Monroe and surrounding areas below.
      </p>
      <a href="#details" class="shadow px-4 btn btn-warning cta-btn-lg py-2 mt-3 saira-stencil-one-regular">
        Read More
        <i class="bi bi-chevron-down"></i>
      </a>
    </div>
  </div>
</div>

<section id="details">
  <div class="container-fluid blur py-5">
    <h1 class="display-3 rubik-dirt-regular text-white mb-5 text-center">Recent Work</h1>
    <% @jobs.each do |job| %>
      <div class="row justify-content-center flex-wrap-reverse px-0 py-3">
        <div class="d-none d-md-block col-md-3">
          <% job.images.each do |image| %>
            <%= image_tag image.variant(:thumb), width: 300, height: 300, class: "img-fluid mb-3" %>
          <% end %>
        </div>

        <div class="col-12 col-sm-10 col-md-8 col-lg-7">
          <div class="card bg-transparent border-0 rounded-0">


                  <div id="carouselJob-<%= job.id %>" class= "carousel slide">
                    <div class="carousel-inner">

                      <div class="carousel-item active">
                            <%= image_tag job.main_image.variant(:large), width: 1000, height: 1000, class: "img-fluid carousel-image" %>
                      </div>

                      <% job.images.each do |image| %>
                        <div class="carousel-item">
                              <%= image_tag image.variant(:large), width: 1000, height: 1000, class: "img-fluid carousel-image" %>
                        </div>
                      <% end %>

                    </div>

                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselJob-<%= job.id %>" data-bs-slide="prev">
                      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                      <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carouselJob-<%= job.id %>" data-bs-slide="next">
                      <span class="carousel-control-next-icon" aria-hidden="true"></span>
                      <span class="visually-hidden">Next</span>
                    </button>

                  </div>

              <div class="card-body d-flex flex-column justify-content-between">

                <div class="card-text saira-stencil-one-regular text-white">
                  <p><span class="rubik-mono-one-regular">Location: </span><%= job.location %></p>
                  <p><span class="rubik-mono-one-regular">Description of work: </span><%= job.description %></p>
                </div>

              </div>
          </div>
        </div>

      </div>
        <div class="container px-5 mb-5 border-bottom">
        </div>
    <% end %>
  </div>
</section>
