    <div class="row py-5 justify-content-center">
      <!-- About Hero -->
      <div class="col-12 col-sm-5 col-md-4 col-xl-3">
        <%= image_tag "about-us.webp", class: "img-fluid" %>
      </div>
      <!-- About CTA -->
      <div class="col-12 col-sm-6 col-xl-4 d-flex align-items-center">
