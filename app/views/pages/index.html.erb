          <div class="container d-flex justify-content-end pe-5">
            <%= link_to "Read More",
              about_path,
              class: "cta-btn btn text-nowrap btn-warning pt-2 btn-sm-lg shadow saira-stencil-one-regular", style: "text-shadow: none;" %>
          </div>
        </div>
      </div>
    </div>

