<div class="card blur col-12 col-sm-8 col-md-6 col-xl-4">
  <div class="card-body">

    <div class="card-text saira-stencil-one-regular text-white">
      <p><span class="fs-5">Location: </span><%= recent_job.location %></p>
      <p><span class="fs-5">Description of work: </span><%= recent_job.description %></p>
    </div>

    <div class="text-light border-top pt-3 w-100 d-flex justify-content-between show-controls align-items-start">
      <%= link_to "Edit", edit_admin_recent_job_path(recent_job), class: "btn btn-warning cta-btn saira-stencil-one-regular" %>

      <%= button_to "Destroy",
        admin_recent_job_path(recent_job),
        method: :delete,
        form: { data: { turbo_confirm: "Are you sure you want to delete this testimonial?" }},
        class: "saira-stencil-one-regular btn btn-danger cta-btn" %>
    </div>

  </div>
</div>
