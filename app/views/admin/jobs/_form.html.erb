<%= form_with(model: admin_job) do |form| %>
  <% if admin_job.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(admin_job.errors.count, "error") %> prohibited this admin_job from being saved:</h2>

      <ul>
        <% admin_job.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :location, style: "display: block", class: "saira-stencil-one-regular" %>
    <%= form.text_field :location %>
  </div>

  <div>
    <%= form.label :description, style: "display: block", class: "saira-stencil-one-regular" %>
    <%= form.textarea :description %>
  </div>

  <div>
    <%= form.label :main_image, style: "display: block", class: "saira-stencil-one-regular" %>
    <%= form.file_field :main_image, class: "form-control", accept: 'image/*' %>
  </div>

  <div>
    <%= form.label :images, style: "display: block", class: "saira-stencil-one-regular" %>
    <%= form.file_field :images, class: "form-control", accept: 'image/*', multiple: true %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
