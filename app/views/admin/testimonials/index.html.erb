<p  class="text-center saira-stencil-one-regular text-warning text-shadow-light fs-4 my-3"><%= notice %></p>

<% content_for :title, "Testimonials" %>

<h1 class="rubik-dirt-regular display-3 text-center text-white">Testimonials</h1>

