    <div class="col-12 col-sm-8 col-md-7 col-lg-5 col-xl-4 col-xxl-3">
      <div class="card blur rounded-0 border-0 shadow mb-4 admin-testimonial-card">
        <div class="card-body d-flex flex-column align-items-center justify-content-center p-3">

          <% if testimonial.image.attached? %>
            <%= image_tag testimonial.image.variant(:avatar), class: "avatar" %>
          <% else %>
            <%= image_tag "placeholder-avatar.png", class: "avatar" %>
          <% end %>

          <div class="pt-5 card-text">
            <figure class="text-center">
              <blockquote class="blockquote px-3">
                <p class="text-white">
                  <%= testimonial.testimony %>
                </p>
              </blockquote>
              <figcaption class="blockquote-footer">
                <%= "#{testimonial.client_type}" %>, <cite title="Source Title"><%= testimonial.name.titleize %></cite>
              </figcaption>
            </figure>
          </div>
          <div class="text-light border-top  mt-auto pt-3 w-100 d-flex justify-content-between show-controls align-items-start px-3 px-sm-3">
            <%= link_to "Edit", edit_admin_testimonial_path(testimonial), class: "btn btn-warning cta-btn saira-stencil-one-regular" %>

            <%= button_to "Destroy",
              admin_testimonial_path(testimonial),
              method: :delete,
              form: { data: { turbo_confirm: "Are you sure you want to delete this testimonial?" }},
              class: "saira-stencil-one-regular btn btn-danger cta-btn" %>
          </div>
        </div>
      </div>
    </div>
