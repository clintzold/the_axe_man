<div class="container-fluid py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5">
      <div class="card-body d-flex flex-column align-items-center justify-content-center blur p-3">
        <%= image_tag testimonial.image.variant(:avatar), class: "avatar" %>
        <div class="pt-5 testimonial">
          <figure class="text-center">
            <blockquote class="blockquote px-3">
              <p class="text-white">
                <%= testimonial.testimony %>
              </p>
            </blockquote>
            <figcaption class="blockquote-footer">
              <%= "#{testimonial.location} #{testimonial.client_type}" %>, <cite title="Source Title"><%= testimonial.name.titleize %></cite>
            </figcaption>
          </figure>
        </div>
        <div class="text-light border-top pt-3 w-100 d-flex justify-content-between show-controls align-items-start px-5">
          <%= link_to "Edit", edit_admin_testimonial_path(testimonial), class: "btn btn-warning cta-btn saira-stencil-one-regular" %>

          <%= button_to "Destroy",
            admin_testimonial_path(testimonial),
            method: :delete,
            form: { data: { turbo_confirm: "Are you sure you want to delete this testimonial?" }},
            class: "saira-stencil-one-regular btn btn-danger cta-btn" %>
        </div>
      </div>
    </div>
  </div>
</div>
